# ============================================================
# Vault — Next.js + MongoDB .gitignore
# ============================================================

# ─── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Next.js Build Output ─────────────────────────────────
.next/
out/
build/
dist/

# ─── Environment Variables (NEVER commit these!) ──────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Vercel / Deployment ──────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS & Editor Files ────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE & Editor ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Package Manager Locks (keep package-lock.json) ───────
yarn.lock
pnpm-lock.yaml

# ─── Uploaded / Temporary Files ───────────────────────────
uploads/
tmp/
temp/
*.tmp

# ─── Coverage & Testing ───────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ─────────────────────────────────────────────────
.cache/
.parcel-cache/
