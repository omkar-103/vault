{
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "module": "commonjs",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "outDir": "./dist-scripts"
    },
    "include": [
        "scripts/**/*.ts",
        "lib/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}